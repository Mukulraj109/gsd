# =============================================================================
# GSD — Environment variables (copy to `.env.local` for local development)
# =============================================================================

# Local PostgreSQL:
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gsd"

# Render Postgres from your laptop — use External Database URL + SSL:
# DATABASE_URL="postgresql://USER:PASSWORD@dpg-xxxx-a.singapore-postgres.render.com/DATABASE?sslmode=require"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Admin panel PIN (required in production for /admin/* after login as ADMIN)
ADMIN_GATE_PIN="your-secret-pin"

# Optional demo hints on login/home (localhost shows by default)
# SHOW_TEST_CREDENTIALS=true
# NEXT_PUBLIC_SHOW_TEST_CREDENTIALS=true

# Zepto Mail — https://www.npmjs.com/package/zeptomail (India API for FirstStep)
ZEPTO_API_URL="https://api.zeptomail.in/"
ZEPTO_API_KEY="Zoho-enczapikey your-send-mail-token"
ZEPTO_FROM_EMAIL="noreply@firststepjob.com"
ZEPTO_FROM_NAME="noreply"
# GSD Board: Task Updated (merge: task_name, updated_at, updated_columns, task_url, updated_by)
ZEPTO_TEMPLATE_TASK_UPDATED="2518b.354647c12fb35c26.k1.0d8c7990-518b-11f1-a7f9-fa912d477de9.19e336e07a9"
# GSD Board: New Task Assigned (merge: task_name, task_description, task_url, due_date, assigned_by, priority)
ZEPTO_TEMPLATE_NEW_TASK="2518b.354647c12fb35c26.k1.b4a2f7d0-5187-11f1-a7f9-fa912d477de9.19e335817cd"

# After migrate + seed:
#   npx prisma migrate deploy
#   npx tsx prisma/seed.ts
# Admin: admin@gsd.com / password123
# Member: member@gsd.com / password123
