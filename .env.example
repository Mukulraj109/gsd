# -----------------------------------------------------------------------------
# GSD — local: copy to `.env.local`. Production (Render): see `.env.render.example`
# -----------------------------------------------------------------------------

# PostgreSQL connection string (required). Local example:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gsd"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gsd"

# NextAuth — local:
NEXTAUTH_URL="http://localhost:3000"
# Production — your public URL (https, no trailing slash):
# NEXTAUTH_URL="https://your-service.onrender.com"

# Secret for JWT signing — generate your own: 
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="replace-with-a-long-random-string"
