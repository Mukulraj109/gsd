# =============================================================================
# GSD — Environment variables (copy to `.env.local` for local development)
# =============================================================================
#
# REQUIRED (all environments)
# ---------------------------
# PostgreSQL connection string (Prisma). Must start with postgresql:// or postgres://
#
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gsd"
#
# Public base URL of this app (no trailing slash). Used by NextAuth for callbacks.
# Local:
NEXTAUTH_URL="http://localhost:3000"
#
# Secret for signing JWT sessions. Generate once and keep private:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
NEXTAUTH_SECRET="replace-with-a-long-random-string"
#
#
# OPTIONAL — developer / demo UX (seeded users from prisma/seed.ts)
# ------------------------------
# On localhost, demo hints show automatically. On hosted production (NODE_ENV=production),
# hints show if either variable below is true (both also enable the same on `/`).
#
# SHOW_TEST_CREDENTIALS=true
# NEXT_PUBLIC_SHOW_TEST_CREDENTIALS=true
#
# OPTIONAL — email (password reset, team invites)
# -----------------------------------------------
# Nodemailer / SMTP. Without these, forgot-password and invite emails are skipped
# but APIs still return safely (reset tokens not emailed; team invite returns a copyable signup URL).
#
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_FROM="GSD <no-reply@example.com>"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_SECURE="false"
#
#
# OPTIONAL — OAuth (Google / GitHub)
# ----------------------------------
# When set, login and signup show provider buttons.
#
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_ID=""
# GITHUB_SECRET=""
#
#
# NOT USED by this codebase (omit unless you add features)
# ----------------------------------------------------------
# - No MongoDB / Redis (rate limits are in-memory; use one app instance or add Redis later)
#
#
# After first deploy (Render shell or local): optional demo data
# ----------------------------------------------------------------
#   npx tsx prisma/seed.ts
#
# Seeded logins (password for both: password123):
#   admin@gsd.com   (role ADMIN)
#   member@gsd.com  (role MEMBER)
#
# =============================================================================
