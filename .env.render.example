# Paste each line into Render → Web Service → Environment (or use "Link database").
# Free web tier: no Shell — run `npm run db:seed` from your laptop with the Postgres
# "External Database URL" (see README → Deploying on Render).
# Generate NEXTAUTH_SECRET yourself — do not reuse any example from documentation.

DATABASE_URL=PASTE_RENDER_POSTGRES_INTERNAL_DATABASE_URL_HERE
NEXTAUTH_URL=https://YOUR-SERVICE-NAME.onrender.com
# Show demo login hints on `/`, `/login`, and `/signup` when NODE_ENV=production (staging on Render).
# Remove or set to false before a public production launch.
NEXT_PUBLIC_SHOW_TEST_CREDENTIALS=true

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_FROM=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=false

# Optional: OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_ID=
# GITHUB_SECRET=
